qry <-"with contract_sign as
(
    select distinct
        request_body::json ->> 'cpf' as cpf,
        created_at::date as created_at_cs,
        response_body,
        response_body::json ->> 'status' as contract_sign_status,
        request_body,
        request_body::json ->> 'bank_name' as bank_name,
        request_body::json ->> 'caixa_account_type' as caixa_account_type,
        request_body::json ->> 'bank_account_type' as bank_account_type,
        request_body::json ->> 'bank_account_number' as bank_account_number,
        request_body::json ->> 'bank_branch' as bank_branch
    from simplic_partners.communications
    where request_type = 'contract_sign'
      and created_at >= '2026-01-01'
),

funnel as
(
    select
        source,
        cs.*
    from contract_sign cs
    left join identity.government_identifiers gi
        on cs.cpf = gi.identifier
       and gi.government_identifier_type_id = 5
    left join simplic_portfolio.loan_applications la
        on la.loan_application_id =
        (
            select loan_application_id
            from simplic_portfolio.loan_applications pla
            where pla.brand_id = 6
              and pla.account_id = gi.account_id
              and pla.created_at between cs.created_at_cs - 4 and cs.created_at_cs + 1
            order by loan_application_id desc
            limit 1
        )
    left join simplic_portfolio.sources s
        on la.source_id = s.source_id
   where source ilike '%kwai%'
   or source ilike '%finanzero%'
)

select *
from funnel
order by source, cpf, created_at_cs;"


