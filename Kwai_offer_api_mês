    get(rq.body, 'bank_name')::string as bank_name,
    count(distinct rq.request_id) as volume
from LEADS_PROD.LEADS.REQUESTS rq
left join LEADS_PROD.LEADS.RESPONSES rs using (request_id)
left join LEADS_PROD.LEADS.PROVIDERS pr using (provider_id)
